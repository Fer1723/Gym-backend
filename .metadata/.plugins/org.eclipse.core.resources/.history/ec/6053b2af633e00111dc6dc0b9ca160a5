package gym_system.com.mx.service;

import java.math.BigDecimal;
import java.time.LocalDate;
import java.time.LocalDateTime;
import java.time.temporal.ChronoUnit;
import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.scheduling.annotation.Scheduled;
import org.springframework.stereotype.Service;

import gym_system.com.mx.entity.CatalogoMembresia;
import gym_system.com.mx.entity.Pago;
import gym_system.com.mx.entity.Socio;
import gym_system.com.mx.entity.Suscripcion;
import gym_system.com.mx.repository.MembresiaRepository;
import gym_system.com.mx.repository.PagoRepository;
import gym_system.com.mx.repository.SocioRepository;
import gym_system.com.mx.repository.SuscripcionRepository;
import jakarta.transaction.Transactional;

@Service
public class SuscripcionService {
	
	@Autowired
	private SuscripcionRepository suscripcionRepository;
	
	@Autowired
	private SocioRepository socioRepository;
	
	@Autowired
	private MembresiaRepository membresiaRepository;
	
	@Autowired
	private PagoRepository pagoRepository;
	
	public List<Suscripcion> obtenerTodas(){
		return suscripcionRepository.findByEstado("ACTIVA");
	}
	
	public List<Suscripcion> buscarPorIdSocio(Integer idSocio){
		return suscripcionRepository.findBySocioIdSocio(idSocio);
	}
	
	@Transactional
	public Suscripcion inscribirSocio(Integer idSocio, Integer idMembresia, String metodoPago) {
		
		Socio socio = socioRepository.findById(idSocio)
				.orElseThrow(() -> new RuntimeException("Socio no encontrado"));
		
		CatalogoMembresia membresia = membresiaRepository.findById(idMembresia)
				.orElseThrow(() -> new RuntimeException("Membresia no encontrada"));
	
		List<Suscripcion> historial = suscripcionRepository.findBySocioOrderByFechaFinDesc(socio);
		LocalDate hoy = LocalDate.now();
		
		if(!historial.isEmpty()) {
			Suscripcion ultima = historial.get(0);
			
			if(ultima.getEstado().equals("VENCIDA")) {
				long diasInactivo = ChronoUnit.DAYS.between(ultima.getFechaFin(), hoy);
				
				if(diasInactivo > 30 && !membresia.getNombre().equalsIgnoreCase("RE-INSCRIPCION")) {
					throw new RuntimeException("El socio tiene mas de un mes inactivo (" + diasInactivo + "dias. "+
												"Debe pagar una Re-inscripcion obligatoria.");
				}
			}
		}
		List<Suscripcion> activas = suscripcionRepository.findBySocioAndEstado(socio, "ACTIVA");
		
		LocalDate fechaInicioNueva;
		BigDecimal montoAPagar = membresia.getPrecio(); 
		
		if(!activas.isEmpty()) {
			LocalDate ultimaFechaFin = activas.stream()
					.map(Suscripcion::getFechaFin)
					.max(LocalDate::compareTo)
					.get();
			fechaInicioNueva = ultimaFechaFin;
			
			if((ultimaFechaFin.isEqual(hoy) || ultimaFechaFin.isAfter(hoy)) &&
			(membresia.getDuracionDias() >= 28)){
				BigDecimal descuento;
				double precio = montoAPagar.doubleValue();
				if(precio == 550) {
					descuento = new BigDecimal("20.00");
				}else if(precio == 530) {
					descuento = new BigDecimal("30.00");
				}else if(precio == 500) {
					descuento = new BigDecimal("40.00");
				}else {
					descuento = BigDecimal.ZERO;
				}
				montoAPagar = montoAPagar.subtract(descuento);
				System.out.println("⭐ Renovación Anticipada: Se aplicó descuento de Pronto Pago.");
			} else {
				System.out.println("ℹ️ Cobro normal: No aplica descuento de pronto pago.");
			}
		}else {
			fechaInicioNueva = hoy;
		}
		
		Suscripcion nueva = new Suscripcion();
		nueva.setSocio(socio);
		nueva.setMembresia(membresia);
		nueva.setFechaInicio(fechaInicioNueva);
		
		int dias = membresia.getDuracionDias();
		
		if(dias == 7) {
			nueva.setFechaFin(fechaInicioNueva.plusWeeks(1));
		}else if(dias >= 28 && dias <= 31) {
			nueva.setFechaFin(fechaInicioNueva.plusMonths(1));
		}else if(dias >= 58 && dias <= 62) {
			nueva.setFechaFin(fechaInicioNueva.plusMonths(2));
		}else if(dias >= 360) {
			nueva.setFechaFin(fechaInicioNueva.plusYears(1));
		}else {
			nueva.setFechaFin(fechaInicioNueva.plusDays(dias));
		}
		
		nueva.setEstado("ACTIVA");
		Suscripcion guardada = suscripcionRepository.save(nueva);
		
		Pago pago = new Pago();
		pago.setSuscripcion(guardada);
		
		pago.setMonto(montoAPagar);
		pago.setFechaPago(LocalDateTime.now());
		pago.setMetodoPago(metodoPago);
		pagoRepository.save(pago);
		
		
		return guardada;
		
	}
	
	public Suscripcion actualizarSuscripcion(Integer id, Suscripcion suscripcionActualizada) {
		return suscripcionRepository.findById(id).map(suscripcion ->{
			suscripcion.setFechaInicio(suscripcionActualizada.getFechaInicio());
			suscripcion.setFechaFin(suscripcionActualizada.getFechaFin());
			suscripcion.setEstado(suscripcionActualizada.getEstado());
			return suscripcionRepository.save(suscripcion);
		}).orElseThrow(() -> new RuntimeException("Suscripcion no encontrada"));
	}
	
	public void cancelarSuscripcion(Integer id) {
		Suscripcion suscripcion = suscripcionRepository.findById(id)
				.orElseThrow(() -> new RuntimeException("Suscripcion no encontrada"));
		suscripcion.setEstado("CANCELADA");
		suscripcionRepository.save(suscripcion);
	}
	
	@Scheduled(cron = "0 0 0 * * ?")
	@Transactional
	public void revisarSuscripcionesVencidas() {
		System.out.println("🦉 Velador Nocturno despertando: Buscando planes vencidos...");
		
		LocalDate hoy = LocalDate.now();
		
		List<Suscripcion> vencidas = suscripcionRepository.findByEstadoIgnoreCaseAndFechaFinBefore("ACTIVA", hoy);
		
		if(!vencidas.isEmpty()) {
			for(Suscripcion suscripcion : vencidas) {
				suscripcion.setEstado("VENCIDA");
			}
			suscripcionRepository.saveAll(vencidas);
			System.out.println("✅ Misión cumplida: Se desactivaron " + vencidas.size() + " plances vencidos.");
		}else {
			System.out.println("💤 Todo en orden. Nadie venció hoy. Volviendo a dormir.");
		}
	}
}
