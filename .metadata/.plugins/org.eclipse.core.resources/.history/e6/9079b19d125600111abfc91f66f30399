package gym_system.com.mx.service;

import java.time.LocalDate;
import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.scheduling.annotation.Scheduled;
import org.springframework.stereotype.Component;

import gym_system.com.mx.entity.Suscripcion;
import gym_system.com.mx.repository.SuscripcionRepository;
import jakarta.transaction.Transactional;

@Component
public class TareaProgramadaService {
	
	@Autowired
	private SuscripcionRepository suscripcionRepository;
	
	@Scheduled(cron = "0 0 0 * * ?")
	@Transactional
	public void actualizarVencimientos() {
		LocalDate hoy = LocalDate.now();
		
		List<Suscripcion> vencidas = suscripcionRepository.findAll().stream()
				.filter(s -> s.getFechaFin().isBefore(hoy) && s.getEstado().equals("ACTIVA"))
				.peek(s -> s.setEstado("VENCIDA"))
				.toList();
		
		suscripcionRepository.saveAll(vencidas);
		System.out.println("Se han vencido "+ vencidas.size() + "suscripciones automaticamente.");
	}

}
