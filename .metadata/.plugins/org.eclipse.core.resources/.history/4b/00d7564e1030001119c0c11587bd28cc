import gym_system.com.mx.repository.PagoRepository;
import gym_system.com.mx.repository.SocioRepository;
import gym_system.com.mx.repository.SuscripcionRepository;
import jakarta.transaction.Transactional;

@Service
public class SuscripcionService {
	
	@Autowired
	private SuscripcionRepository suscripcionRepository;
	
	@Autowired
	private SocioRepository socioRepository;
	
	@Autowired
	private MembresiaRepository membresiaRepository;
	
	@Autowired
	private PagoRepository pagoRepository;
	
	public List<Suscripcion> obtenerTodas(){
		return suscripcionRepository.findByEstado("ACTIVA");
	}
	
	@Transactional
	public Suscripcion inscribirSocio(Integer idSocio, Integer idMembresia) {
		
		Socio socio = socioRepository.findById(idSocio)
				.orElseThrow(() -> new RuntimeException("Socio no encontrado"));
		
		CatalogoMembresia membresia = membresiaRepository.findById(idMembresia)
				.orElseThrow(() -> new RuntimeException("Membresia no encontrada"));
		
		List<Suscripcion> activas = suscripcionRepository.findBySocioAndEstado(socio, "Activa");
		
		LocalDate fechaInicioNueva;
		
		if(!activas.isEmpty()) {
			LocalDate ultimaFechaFin = activas.stream()
					.map(Suscripcion::getFechaFin)
					.max(LocalDate::compareTo)
					.get();
			fechaInicioNueva = ultimaFechaFin;
		}else {
			fechaInicioNueva = LocalDate.now();
		}
		
		Suscripcion nueva = new Suscripcion();
		nueva.setSocio(socio);
		nueva.setMembresia(membresia);
		nueva.setFechaInicio(fechaInicioNueva);
		
		if(membresia.getDuracionDias() == 30) {
			nueva.setFechaFin(fechaInicioNueva.plusMonths(1));
		}else if(membresia.getDuracionDias() == 365) {
			nueva.setFechaFin(fechaInicioNueva .plusYears(1));
		}else{
			nueva.setFechaFin(fechaInicioNueva.plusDays(membresia.getDuracionDias()));
		}
		
		nueva.setEstado("Activa");
		Suscripcion guardada = suscripcionRepository.save(nueva);
		
		Pago pago = new Pago();
		pago.setSuscripcion(guardada);
		pago.setMonto(membresia.getPrecio());
