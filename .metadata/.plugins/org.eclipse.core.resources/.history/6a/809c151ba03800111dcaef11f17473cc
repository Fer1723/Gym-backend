package gym_system.com.mx.controller;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;

import gym_system.com.mx.entity.Suscripcion;
import gym_system.com.mx.service.SuscripcionService;

@RestController
@RequestMapping("/api/suscripciones")
public class SuscripcionController {
	
	@Autowired
	private SuscripcionService suscripcionService;
	
	@GetMapping
	public List<Suscripcion> listarSuscripciones(){
		return suscripcionService.obtenerTodas();
	}
	
	@PostMapping("/inscribir")
	public Suscripcion inscribirSuscripcion(@RequestParam Integer idSocio, @RequestParam Integer idMembresia, @RequestParam String metodoPago) {
		return suscripcionService.inscribirSocio(idSocio, idMembresia, metodoPago);
	}
	
	@PutMapping("/{id}")
	public Suscripcion acutualizarSuscripcion(@PathVariable Integer id, @RequestBody Suscripcion suscripcion) {
		return suscripcionService.actualizarSuscripcion(id, suscripcion);
	}
	
	@DeleteMapping("/{id}")
	public void cancelarSuscripcion(@PathVariable Integer id) {
		suscripcionService.cancelarSuscripcion(id);
	}
}
